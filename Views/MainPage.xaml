<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="AirPodsCompanion.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AirPodsCompanion"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <Grid Background="#1c1c1e" Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="AirPods Companion" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,24"/>

            <StackPanel Grid.Row="1" Spacing="20">
                <!-- Device Info Card -->
                <Border Background="#2c2c2e" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock x:Name="DeviceNameText" Text="Waiting for AirPods..." Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <TextBlock x:Name="BatteryStatusText" Text="Battery Information Unavailable" Foreground="#aeaeb2" FontSize="14" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- Settings Controls -->
                <Border Background="#2c2c2e" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Settings" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        
                        <ToggleSwitch x:Name="AutoPauseToggle" Header="Auto Pause on Remove" Foreground="White" IsOn="True" Toggled="AutoPauseToggle_Toggled"/>
                        <ToggleSwitch x:Name="PopupToggle" Header="Show Connection Popup" Foreground="White" IsOn="True"/>
                    </StackPanel>
                </Border>

                <!-- Noise Control (Active when connected) -->
                <Border Background="#2c2c2e" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Noise Control" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="ANC" Background="#3a3a3c" Foreground="White" Click="AncBtn_Click" Width="80"/>
                            <Button Content="Transparency" Background="#3a3a3c" Foreground="White" Click="TransBtn_Click" Width="120"/>
                            <Button Content="Off" Background="#3a3a3c" Foreground="White" Click="OffBtn_Click" Width="80"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Page.Content>
</Page>
